# Sanity Configuration - Example
# Copy this file to .env and update with your actual values

VITE_SANITY_PROJECT_ID=your-project-id
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-03-19

# Optional: For authenticated requests
# VITE_SANITY_TOKEN=your-api-token

# Optional: CDN optimization
# VITE_SANITY_USE_CDN=true

# Instructions:
# 1. Replace 'your-project-id' with your actual Sanity project ID
# 2. Get your project ID from: https://www.sanity.io/manage
# 3. Choose appropriate dataset:
#    - 'production' for live data
#    - 'development' for testing
#    - 'staging' for pre-production
# 4. Add API token if needed for authenticated requests
